# ─────────────────────────────────────────────────────────────────────────────
# LordFarhan Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# SESSION_ID (required for panel/server deployment)
# Get yours from the pairing site, then paste it here.
# It must start with "LordBot" followed by the base64-encoded creds.
# Example: SESSION_ID=LordBotxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SESSION_ID=

# Owner WhatsApp number (international format, no + or spaces)
# Example: OWNER_NUMBER=2348012345678
OWNER_NUMBER=

# Optional: override bot name shown in menus
BOT_NAME=LordFarhan Bot